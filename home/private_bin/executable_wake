#!/bin/bash

# Available PCs (format: "name|mac")
pcs=(
    "prometheus|18:C0:4D:3C:42:BB"
)

# Select PC interactively - show only name but return full entry
select_pc() {
    printf '%s\n' "${pcs[@]}" | \
    fzf --style=minimal --no-info --height=~100% --reverse --select-1 \
        --with-nth=1 --delimiter='|'
}

# Main logic
selected=$(select_pc)
[[ -z "$selected" ]] && exit 0

# Extract components directly from fzf output
name=$(echo "$selected" | cut -d'|' -f1)
mac=$(echo "$selected" | cut -d'|' -f2)

echo "Waking $name ($mac)..."
ssh helios "wakeonlan $mac"
