#!/bin/sh

# Colors for output (with fallback for systems that don't support them)
if [ -t 1 ] && command -v tput > /dev/null 2>&1 && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
    RED=$(tput setaf 1)
    YELLOW=$(tput setaf 3)
    GREEN=$(tput setaf 2)
    BOLD=$(tput bold)
    NC=$(tput sgr0)
else
    RED=""
    YELLOW=""
    GREEN=""
    BOLD=""
    NC=""
fi

PATTERN="(no|dont)[-_]*commit"

# Use git grep on the index (staged files) - this works everywhere Git works
# The --cached flag searches the staged content, not working directory

if git grep --cached -q -i -E "$PATTERN" 2>/dev/null; then
    # Redirect output to stderr.
    exec 1>&2

    echo ""
    echo "${YELLOW}Found 'nocommit' or 'dontcommit' markers in staged files:${NC}"
    echo ""
    
    # Show which files and lines contain violations
    git grep --cached -n -i -E "$PATTERN" 2>/dev/null | while IFS= read -r line; do
        echo "  ${RED}$line${NC}"
    done
    
    echo ""
    echo "${YELLOW}Please remove these markers before committing.${NC}"
    echo ""
    echo "To bypass this check: ${BOLD}git commit --no-verify${NC}"
    exit 1
fi