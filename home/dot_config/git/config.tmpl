[user]
	name = Clay Tercek
	email = 30105080+claytercek@users.noreply.github.com
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[core]
	excludesFile = {{ joinPath .chezmoi.homeDir ".config/git/ignore" | quote }}
{{ if .personal }}
[user]
	signingkey = {{ onepasswordRead "op://Personal/Github/public key" | trim }}
{{ if eq .chezmoi.os "windows" }}
[core]
	sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
	autocrlf = true
[gpg "ssh"]
	program = {{ joinPath .chezmoi.homeDir "AppData/Local/Microsoft/WindowsApps/op-ssh-sign.exe" | quote }}
	allowedSignersFile = {{ .chezmoi.homeDir }}/.ssh/allowed_signers
{{ end }}
{{ if .wsl }}
[core]
	sshCommand = ssh.exe
[gpg "ssh"]
	program = "/mnt/c/Users/clayt/AppData/Local/Microsoft/WindowsApps/op-ssh-sign-wsl.exe"
	allowedSignersFile = {{ .chezmoi.homeDir }}/.ssh/allowed_signers
{{ end }}
{{ if eq .chezmoi.os "darwin" }}
[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
	allowedSignersFile = {{ .chezmoi.homeDir }}/.ssh/allowed_signers
{{ end }}
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
{{ end }}
[init]
	defaultBranch = main
	templateDir = {{ joinPath .chezmoi.homeDir ".config/git/template" | quote }}

[url "git@github.com:"]
  insteadOf = gh:

[url "git@github.com:bluecadet/"]
  insteadOf = bc:

[url "git@github.com:claytercek/"]
  insteadOf = ct: